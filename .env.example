# Database (PostgreSQL in production, SQLite for local dev)
# Local SQLite example:
# DATABASE_URL="file:./prisma/teacherbot.db"
# PostgreSQL example:
# DATABASE_URL="postgresql://user:password@localhost:5432/teacherbot?schema=public"
DATABASE_URL="file:./prisma/teacherbot.db"

# Telegram Mini App / Bot
# Сюда вставьте токен вашего бота из BotFather
TELEGRAM_BOT_TOKEN=""
# Токен тестового бота (используется локальным запуском через npm run start:local)
TELEGRAM_TEST_BOT_TOKEN=""
# Публичный HTTPS URL вашего фронтенда (например, https://<ngrok-id>.ngrok-free.app)
# Для локальной разработки вне Telegram можно указать http://localhost:5173
TELEGRAM_WEBAPP_URL="http://localhost:5173"
# YooKassa (для генерации ссылки оплаты подписки)
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""
YOOKASSA_RETURN_URL="http://localhost:5173"
# Требовать Basic auth на webhook `/api/yookassa/webhook`.
# В production рекомендуется оставить `true`.
YOOKASSA_WEBHOOK_REQUIRE_AUTH=true

# API / App
# Публичный базовый URL приложения (используется для генерации ссылок)
APP_BASE_URL="http://localhost:5173"
# Порт API сервера (по умолчанию 4000)
API_PORT=4000

# HTTP/CORS security
# Разрешённые origin для CORS (через запятую), пример:
# CORS_ALLOWED_ORIGINS="https://app.example.com,https://admin.example.com"
CORS_ALLOWED_ORIGINS=""
CORS_ALLOW_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOW_HEADERS="Content-Type, X-User-Role, X-Student-Id, X-Teacher-Id"
CORS_MAX_AGE_SEC=600

# Защита от CSRF-like запросов с чужих origin
# В production рекомендуется `true`
SECURITY_ENFORCE_ORIGIN_CHECK=true
# Разрешать mutating-запросы без Origin/Referer (обычно только для локальной разработки)
SECURITY_ALLOW_MISSING_ORIGIN=false

# HSTS (в секундах) для HTTPS
SECURITY_HSTS_MAX_AGE_SEC=15552000

# Ограничения и таймауты API
API_JSON_BODY_LIMIT_BYTES=1048576
API_REQUEST_TIMEOUT_MS=60000
API_HEADERS_TIMEOUT_MS=65000
API_KEEP_ALIVE_TIMEOUT_MS=5000

# Telegram WebApp security (optional tuning)
TELEGRAM_INITDATA_TTL_SEC=300
TELEGRAM_REPLAY_SKEW_SEC=60

# Session / auth
SESSION_TTL_MINUTES=1440
TRANSFER_TOKEN_TTL_SEC=120
TRANSFER_REDIRECT_URL="/dashboard"

# Local development auth bypass (disabled in production automatically)
# LOCAL_AUTH_BYPASS=true
# VITE_LOCAL_AUTH_BYPASS=true
# LOCAL_DEV_TELEGRAM_ID=999999999
# LOCAL_DEV_USERNAME="local_teacher"
# LOCAL_DEV_FIRST_NAME="Local"
# LOCAL_DEV_LAST_NAME="Teacher"

# Docker Postgres (for npm run db:local)
# DB_CONTAINER_NAME="teacherbot-db"
# POSTGRES_DB="teacherbot"
# POSTGRES_USER="teacherbot_user"
# POSTGRES_PASSWORD="teacherbot_pass"
# POSTGRES_PORT=5432

# Rate limits (optional)
RATE_LIMIT_WEBAPP_PER_MIN=30
RATE_LIMIT_TRANSFER_CREATE_PER_MIN=3
RATE_LIMIT_TRANSFER_CREATE_IP_PER_MIN=10
RATE_LIMIT_TRANSFER_CONSUME_IP_PER_MIN=10
RATE_LIMIT_TRANSFER_CONSUME_TOKEN_PER_MIN=5

# Notifications
NOTIFICATION_LOG_RETENTION_DAYS=30

# Frontend API base (set if API is on another domain)
# Оставьте пустым, чтобы Vite proxy отправлял запросы на http://localhost:4000
VITE_API_BASE=""
