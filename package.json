{
  "name": "teacherbot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:local": "./scripts/dev-local.sh",
    "dev:local:bot": "./scripts/dev-local-bot.sh",
    "db:local": "./scripts/db-local.sh",
    "api": "prisma generate && tsx src/backend/server.ts",
    "api:prod": "prisma migrate deploy && prisma generate && tsx src/backend/server.ts",
    "bot": "tsx src/backend/telegramBot.ts",
    "start:local": "./scripts/start-local-dev.sh",
    "start:all": "./scripts/start-all.sh",
    "start:prod": "npm run build && npx pm2 start ecosystem.config.cjs && npx pm2 save",
    "stop:prod": "npx pm2 stop ecosystem.config.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:migrate": "prisma migrate dev --skip-generate",
    "prisma:migrate:local": "./scripts/prisma-migrate-local.sh",
    "prisma:reset": "prisma migrate reset --force --skip-generate",
    "prisma:repair": "./scripts/prisma-repair.sh",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "backfill:homework:v2": "tsx scripts/backfill-homework-v2.ts",
    "prisma:seed": "tsx prisma/seed.ts",
    "prepare": "husky"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.6",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@prisma/client": "^5.20.0",
    "@reduxjs/toolkit": "^1.9.5",
    "date-fns": "^2.30.0",
    "dotenv": "^16.4.5",
    "pm2": "^5.4.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.2",
    "react-router-dom": "^6.26.2",
    "react-select": "^5.10.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.5.6",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.7",
    "@types/react-select": "^5.0.0",
    "@vitejs/plugin-react": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prisma": "^5.20.0",
    "tsx": "^4.19.0",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^4.5.0",
    "vitest": "^4.1.5"
  }
}
